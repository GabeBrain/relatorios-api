# Supabase — credenciais do projeto (frontend)
# A publishable key é a chave ANON (pública por design). Ainda assim, o .env
# não deve ser versionado. Copie este arquivo para .env e preencha.
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Segredos de backend (ex.: OPENAI_API_KEY usado pela edge function analyze-slide)
# NÃO ficam aqui — configure-os nos Secrets do Supabase.
